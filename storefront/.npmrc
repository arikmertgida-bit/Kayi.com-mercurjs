# Hoist all packages to root node_modules.
# Required so that @medusajs/ui can resolve its CSS files (browser/default-stylesheet.css)
# during Next.js static page generation — pnpm's strict symlink layout causes the
# readFileSync call inside the bundled server chunk to look for the file relative to
# process.cwd() (/app/browser/...) which does not exist without hoisting.
shamefully-hoist=true
