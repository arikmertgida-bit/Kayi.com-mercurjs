# kayi-messenger environment variables
# Copy to .env and fill in values

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kayi_messenger"
JWT_SECRET="supersecret"
PORT=4000
NODE_ENV="development"

# Backend URL (for display name lookups)
BACKEND_URL="http://localhost:9000"

# Internal secret — must match MESSENGER_INTERNAL_SECRET in backend .env
MESSENGER_INTERNAL_SECRET="kayi-internal-secret"

# CORS — comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3000,http://localhost:7001"

# MinIO (matches docker-compose)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9002
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin123"
MINIO_BUCKET="medusa-media"
MINIO_PUBLIC_URL="http://localhost:9002"
